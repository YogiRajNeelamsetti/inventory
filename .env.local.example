# Local Docker Compose environment (Supabase-first default)
# Use Supabase session pooler endpoint (port 5432).
COMPOSE_DB_URL=jdbc:postgresql://aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
COMPOSE_DB_USERNAME=postgres.<project-ref>
COMPOSE_DB_PASSWORD=<supabase-db-password>

# Optional local PostgreSQL fallback (enable db profile and switch values)
# COMPOSE_DB_NAME=kirana_db
# COMPOSE_DB_URL=jdbc:postgresql://db:5432/kirana_db
# COMPOSE_DB_USERNAME=kirana
# COMPOSE_DB_PASSWORD=password123
# COMPOSE_LOCAL_DB_USERNAME=kirana
# COMPOSE_LOCAL_DB_PASSWORD=password123

# Local app settings
COMPOSE_JWT_SECRET=<local-dev-jwt-secret-min-32-chars>
COMPOSE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost
COMPOSE_GOOGLE_CLIENT_ID=<google-oauth-client-id>.apps.googleusercontent.com
