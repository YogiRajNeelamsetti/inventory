# Supabase (default for all environments)
# Use session pooler host on port 5432 for Spring/Hikari stability.
DB_URL=jdbc:postgresql://aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=<supabase-db-password>

# Optional local PostgreSQL fallback (uncomment to use Docker db service)
# DB_URL=jdbc:postgresql://db:5432/kirana_db
# DB_USERNAME=kirana
# DB_PASSWORD=password123

# JWT - MUST be at least 256 bits (32+ characters)
JWT_SECRET=<generate-strong-secret-min-32-chars>

# CORS - comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=<google-oauth-client-id>.apps.googleusercontent.com
